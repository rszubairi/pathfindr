# API Configuration
NEXT_PUBLIC_API_URL=http://localhost:4000/api
NEXT_PUBLIC_API_VERSION=v1

# Authentication
NEXT_PUBLIC_JWT_SECRET=your-jwt-secret-key-change-in-production

# OAuth
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id
NEXT_PUBLIC_APPLE_CLIENT_ID=your-apple-client-id

# Payment Gateway (Xendit)
XENDIT_SECRET_KEY=xnd_development_...   # from Xendit dashboard — Settings > API Keys
XENDIT_WEBHOOK_TOKEN=...                # from Xendit dashboard — Settings > Callbacks > Verification Token

# File Upload
NEXT_PUBLIC_MAX_FILE_SIZE=5242880
NEXT_PUBLIC_UPLOAD_URL=http://localhost:4000/uploads

# Features
NEXT_PUBLIC_ENABLE_AUTO_APPLY=true
NEXT_PUBLIC_ENABLE_AI_MATCHING=true

# Analytics
NEXT_PUBLIC_GA_TRACKING_ID=
NEXT_PUBLIC_HOTJAR_ID=

# Environment
NODE_ENV=development
