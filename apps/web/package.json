{
  "name": "@pathfindr/web",
  "version": "1.0.0",
  "private": true,
  "description": "Pathfindr Web Application - React with Next.js",
  "scripts": {
    "dev": "next dev",
    "dev:convex": "npx convex dev",
    "prebuild": "npx convex deploy --cmd 'echo Convex deployed' --typecheck=disable || npx convex codegen --typecheck=disable || echo 'Convex codegen skipped'",
    "build": "next build",
    "build:prod": "npx convex deploy && npm run build",
    "start": "next start",
    "lint": "next lint",
    "type-check": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "convex:deploy": "npx convex deploy",
    "convex:seed": "npx convex run seed:seedScholarships",
    "convex:clear": "npx convex run seed:clearScholarships"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.9.1",
    "@reduxjs/toolkit": "^2.3.0",
    "@tanstack/react-query": "^5.62.7",
    "@typescript-eslint/eslint-plugin": "8.56.1",
    "@typescript-eslint/parser": "8.56.1",
    "aws-sdk": "^2.1693.0",
    "axios": "^1.7.9",
    "bcryptjs": "^3.0.3",
    "clsx": "^2.1.1",
    "convex": "^1.32.0",
    "date-fns": "^4.1.0",
    "firebase": "^12.11.0",
    "i18next": "^25.8.18",
    "i18next-browser-languagedetector": "^8.2.1",
    "jsonwebtoken": "^9.0.3",
    "jwt-decode": "^4.0.0",
    "lucide-react": "^0.577.0",
    "next": "^16.1.6",
    "nodemailer": "8.0.1",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-hook-form": "^7.54.1",
    "react-i18next": "^16.5.8",
    "react-redux": "^9.2.0",
    "resend": "^6.9.3",
    "stripe": "^20.4.1",
    "tailwind-merge": "^2.5.5",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.4.2",
    "@testing-library/react": "^14.2.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.11.20",
    "autoprefixer": "^10.4.18",
    "eslint": "^8.56.0",
    "eslint-config-next": "^16.1.6",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^30.2.0",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.3.3"
  }
}
