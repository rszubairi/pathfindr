    "eslint-config-next": "16.1.6",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "firebase-admin": "^13.7.0",
    "helmet": "^7.1.0",
    "jest-environment-jsdom": "30.2.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "next": "16.1.6",
    "nodemailer": "^8.0.1",
