    "db:seed": "tsx src/db/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.10.0",
    "aws-sdk": "^2.1693.0",
    "bcrypt": "^6.0.0",
    "cors": "^2.8.5",
