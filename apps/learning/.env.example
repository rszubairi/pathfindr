# Convex Backend
EXPO_PUBLIC_CONVEX_URL=https://your-convex-deployment.convex.cloud

# AI Tutor Service
EXPO_PUBLIC_AI_TUTOR_API_KEY=your-ai-tutor-api-key
EXPO_PUBLIC_AI_TUTOR_ENDPOINT=https://api.your-ai-service.com/v1

# Sentry Error Tracking
EXPO_PUBLIC_SENTRY_DSN=your-sentry-dsn

# App Configuration
EXPO_PUBLIC_APP_ENV=development
EXPO_PUBLIC_APP_VERSION=1.0.0

# Feature Flags
EXPO_PUBLIC_ENABLE_AI_TUTOR=true
EXPO_PUBLIC_ENABLE_OFFLINE_MODE=false