{
  "name": "pathfindr-monorepo",
  "version": "1.0.0",
  "private": true,
  "description": "Pathfindr - Student Opportunity Platform",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev:web": "npm run dev --workspace=@pathfindr/web",
    "dev:mobile": "npm run start --workspace=@pathfindr/mobile",
    "dev:backend": "npm run dev --workspace=@pathfindr/backend",
    "build:web": "npm run build --workspace=@pathfindr/web",
    "build:mobile": "npm run build --workspace=@pathfindr/mobile",
    "build:backend": "npm run build --workspace=@pathfindr/backend",
    "lint": "npm run lint --workspaces",
    "test": "npm run test --workspaces",
    "clean": "rm -rf node_modules && rm -rf apps/*/node_modules && rm -rf packages/*/node_modules",
    "convex:dev": "npx convex dev",
    "convex:deploy": "npx convex deploy",
    "convex:seed": "npx convex run seed:seedScholarships"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "convex": "^1.32.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "keywords": [
    "pathfindr",
    "student",
    "scholarship",
    "university",
    "internship",
    "job",
    "opportunity",
    "platform"
  ],
  "author": "Pathfindr Team",
  "license": "UNLICENSED",
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "jsonwebtoken": "^9.0.3",
    "resend": "^6.9.3"
  }
}
